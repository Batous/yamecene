generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  role              String   @default("mecene") // 'porteur' | 'mecene' | 'admin' | 'partenaire'
  email             String   @unique
  name              String?
  phone             String?
  city              String?
  country           String?
  mobileMoneyConfig String?  // JSON string: { operator, number, aggregator }
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  causesSubmitted   Cause[]  @relation("PorteurCauses")
  donsMade          Don[]    @relation("MeceneDons")
  ceintures         Ceinture[]
}

model AccessCode {
  id        String    @id @default(cuid())
  code      String    @unique @default(cuid())
  type      String    @default("direct") // 'direct' | 'lot'
  issuedBy  String?   // email admin or partner
  usedBy    String?   // FK users
  usedAt    DateTime?
  status    String    @default("available") // 'available' | 'used' | 'suspended'
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  cause     Cause?
}

model Cause {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  summary     String?
  description String
  type        String?     // famille de cause
  city        String?
  country     String?
  reference   String?     // qui connaît le porteur
  goalAmount  Float?
  currency    String      @default("CDF")
  status      String      @default("pending") // 'pending' | 'active' | 'closed' | 'rejected'
  payoutModel String      @default("fund_manager") // 'fund_manager' | 'direct' | 'multisig'
  approvalThreshold Int   @default(0)
  fundManagerRef String?
  porteurId   String
  accessCode  String?   @unique
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  porteur     User        @relation("PorteurCauses", fields: [porteurId], references: [id])
  accessCodeRel AccessCode?  @relation(fields: [accessCode], references: [code])
  milestones  Milestone[]
  dons        Don[]
  signatories Signatory[]
  payoutRequests PayoutRequest[]
}

model Milestone {
  id        String    @id @default(cuid())
  causeId   String
  label     String
  target    Float
  reached   Boolean   @default(false)
  reachedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  cause     Cause     @relation(fields: [causeId], references: [id], onDelete: Cascade)
}

model Don {
  id          String    @id @default(cuid())
  causeId     String
  meceneId    String?   // nullable si discret
  amount      Float
  currency    String    @default("CDF")
  commission  Float
  netPorteur  Float
  method      String    @default("mobile_money") // local payment method selected at checkout
  status      String    @default("pending") // 'pending' | 'confirmed' | 'failed'
  displayName String?   // nom affiché ou pseudonyme
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  cause       Cause     @relation(fields: [causeId], references: [id], onDelete: Cascade)
  mecene      User?     @relation("MeceneDons", fields: [meceneId], references: [id])
  poem        Poem?
  payment     Payment?
}

model Payment {
  id              String   @id @default(cuid())
  donId           String   @unique
  provider        String
  providerRef     String?  @unique
  status          String   @default("created") // 'created' | 'pending' | 'confirmed' | 'failed' | 'expired'
  checkoutUrl     String?
  providerPayload Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  don             Don      @relation(fields: [donId], references: [id], onDelete: Cascade)
  webhookEvents   WebhookEvent[]
}

model WebhookEvent {
  id              String   @id @default(cuid())
  provider        String
  eventId         String
  eventType       String?
  paymentId       String?
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  payment         Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
}

model Signatory {
  id              String   @id @default(cuid())
  causeId         String
  userId          String
  role            String
  createdAt       DateTime @default(now())

  cause           Cause    @relation(fields: [causeId], references: [id], onDelete: Cascade)
  approvals       PayoutApproval[]

  @@unique([causeId, userId])
}

model PayoutRequest {
  id              String   @id @default(cuid())
  causeId         String
  amount          Float
  currency        String
  provider        String
  providerRef     String?  @unique
  payoutModel     String
  status          String   @default("pending") // 'pending' | 'partial_approval' | 'approved' | 'paid' | 'rejected'
  approvalThreshold Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cause           Cause    @relation(fields: [causeId], references: [id], onDelete: Cascade)
  approvals       PayoutApproval[]
}

model PayoutApproval {
  id              String   @id @default(cuid())
  payoutRequestId String
  signatoryId     String
  approvedAt      DateTime @default(now())

  payoutRequest   PayoutRequest @relation(fields: [payoutRequestId], references: [id], onDelete: Cascade)
  signatory       Signatory     @relation(fields: [signatoryId], references: [id], onDelete: Cascade)

  @@unique([payoutRequestId, signatoryId])
}

model Ceinture {
  id        String    @id @default(cuid())
  meceneId  String
  level     String    // 'blanche' | 'jaune' | 'verte' | 'bleue' | 'rouge' | 'noire' | 'or'
  awardedAt DateTime  @default(now())
  note      String?   // motif attribution
  createdAt DateTime  @default(now())

  mecene    User      @relation(fields: [meceneId], references: [id], onDelete: Cascade)
}

model Poem {
  id        String    @id @default(cuid())
  donId     String    @unique
  content   String
  generated Boolean   @default(true)
  validated Boolean   @default(false)
  published Boolean   @default(false)
  createdAt DateTime  @default(now())

  don       Don       @relation(fields: [donId], references: [id], onDelete: Cascade)
}
